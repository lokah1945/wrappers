# wrapper-nvidia example env — copy to .env and fill in real keys.
# Production keys MUST never be committed to version control.

# NVIDIA NIM API Keys (5 free-tier keys rotation pool — Tambah sebanyak yang diperlukan)
NVIDIA_API_KEY_1=
NVIDIA_API_KEY_2=
NVIDIA_API_KEY_3=
NVIDIA_API_KEY_4=
NVIDIA_API_KEY_5=

# Rate limit per key
SOFT_LIMIT_RPM=30
HARD_LIMIT_RPM=40

# Server
LISTEN_HOST=0.0.0.0
LISTEN_PORT=9100

# NVIDIA base URLs
NVIDIA_BASE_URL=https://integrate.api.nvidia.com
NVIDIA_GENAI_URL=https://ai.api.nvidia.com
NVIDIA_NVCF_URL=https://api.nvcf.nvidia.com

# Queue & pacing
QUEUE_LIMIT=4
KEYS_RELOAD_SECONDS=60

# Throughput stability (see README)
MAX_CONNECTIONS=1000
MAX_QUEUE_SIZE=500
INFLIGHT_SOFT_CAP=50
LOAD_SHEDDING_ENABLED=true
REQUEST_TIMEOUT_SEC=60
VERIFY_CONCURRENCY=16

# Optional bearer auth (empty = open)
BEARER_TOKEN=

# Structured JSON log sink
WRAPPER_JSON_LOG=true

# ── Hardening 2026-06-30 (anti-silent-hang) ──
# Anti-silence response guard: MUST be >= STREAM_REQUEST_TIMEOUT_SEC + 60s buffer
# so a healthy (heartbeating) stream is never killed by the server socket layer
# before the fetch timeout fires a clean abort. A value of 45000 silently 504'd
# large reasoning models (nemotron-3-ultra, deepseek-v4-pro, glm-5.x) that hold
# the socket silently for 60-150s+ while thinking; the documented safe default
# is 960000 (>= 900s stream timeout + 60s). Removed from wrapper-nvidia.service.
ANTI_SILENCE_TIMEOUT_MS=960000
# Per-socket server timeout (this is the BIG one — was 300000).
SERVER_REQUEST_TIMEOUT_MS=60000
# Keep-alive socket timeout (was 75000 — caused 75s hang during agent abort).
SERVER_KEEPALIVE_TIMEOUT_MS=10000
# Header parse timeout (was unlimited — caused hangs on slow clients).
SERVER_HEADERS_TIMEOUT_MS=15000
