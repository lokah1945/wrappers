# wrapper-nvidia example env — copy to .env and fill in real keys.
# Production keys MUST never be committed to version control.

# NVIDIA NIM API Keys (5 free-tier keys rotation pool — Tambah sebanyak yang diperlukan)
NVIDIA_API_KEY_1=
NVIDIA_API_KEY_2=
NVIDIA_API_KEY_3=
NVIDIA_API_KEY_4=
NVIDIA_API_KEY_5=

# Rate limit per key
SOFT_LIMIT_RPM=30
HARD_LIMIT_RPM=40

# Server
LISTEN_HOST=0.0.0.0
LISTEN_PORT=9101

# NVIDIA base URLs
NVIDIA_BASE_URL=https://integrate.api.nvidia.com
NVIDIA_GENAI_URL=https://ai.api.nvidia.com
NVIDIA_NVCF_URL=https://api.nvcf.nvidia.com

# Queue & pacing
QUEUE_LIMIT=4
KEYS_RELOAD_SECONDS=60

# Throughput stability (see README)
MAX_CONNECTIONS=1000
MAX_QUEUE_SIZE=500
INFLIGHT_SOFT_CAP=100
LOAD_SHEDDING_ENABLED=true
REQUEST_TIMEOUT_SEC=300
STREAM_REQUEST_TIMEOUT_SEC=900
VERIFY_CONCURRENCY=16

# Undici agent timeouts
HEADERS_TIMEOUT_MS=180000
PRE_RESPONSE_TIMEOUT_MS=300000
TTFT_TIMEOUT_MS=120000

# Optional bearer auth (empty = open)
BEARER_TOKEN=

# Structured JSON log sink
WRAPPER_JSON_LOG=true

# ── Server-Level Socket Timeouts (anti-silent-hang) ──
# ANTI_SILENCE_TIMEOUT_MS: must be >= STREAM_REQUEST_TIMEOUT_SEC + 60s buffer
# so a healthy (heartbeating) stream is never killed by the server socket layer
# before the fetch timeout fires a clean abort.
ANTI_SILENCE_TIMEOUT_MS=960000
# Keep-alive socket timeout (was 10000 — dangerously low for reasoning models).
SERVER_KEEPALIVE_TIMEOUT_MS=65000
# Header parse timeout (was 15000 — too tight for slow clients).
SERVER_HEADERS_TIMEOUT_MS=35000
