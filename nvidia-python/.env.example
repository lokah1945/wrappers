# NVIDIA NIM API Keys (add as many as needed)
NVIDIA_API_KEY_1=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_API_KEY_2=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_API_KEY_3=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Rate limit settings
SOFT_LIMIT_RPM=30
HARD_LIMIT_RPM=40

# Server settings
LISTEN_HOST=0.0.0.0
LISTEN_PORT=9101
METRICS_DB=metrics.db
NVIDIA_BASE_URL=https://integrate.api.nvidia.com
QUEUE_LIMIT=4
KEYS_RELOAD_SECONDS=60

# Throughput Stability Settings
MAX_CONNECTIONS=1000
MAX_QUEUE_SIZE=500
INFLIGHT_SOFT_CAP=100
LOAD_SHEDDING_ENABLED=true
HEADERS_TIMEOUT_MS=180000
PRE_RESPONSE_TIMEOUT_MS=300000
PACING_MAX_WAIT=120
REQUEST_TIMEOUT=300
STREAM_REQUEST_TIMEOUT_SEC=900
VERIFY_CONCURRENCY=16
VERIFY_ON_BOOT=false

# Auth (optional). Empty = open local proxy.
BEARER_TOKEN=wrapper-local-key

# Logging
WRAPPER_JSON_LOG=true
STREAM_HEARTBEAT=true

# Parameter Injection
WRAPPER_PARAMS=temperature,top_p
DEFAULT_TEMPERATURE=0.7
DEFAULT_TOP_P=1.0
DROP_PARAMS=think
TTFT_TIMEOUT_MS=120000

# Server / stream timeouts (reasoning-model friendly)
ANTI_SILENCE_TIMEOUT_MS=960000
SERVER_KEEPALIVE_TIMEOUT_MS=65000
SERVER_HEADERS_TIMEOUT_MS=35000
GEN_TIMEOUT_SEC=900

# Claude Code aliases (optional overrides). Wrapper stays transparent for explicit model ids.
# CLAUDE_CODE_DEFAULT_HAIKU_MODEL=meta/llama-3.1-8b-instruct
# CLAUDE_CODE_DEFAULT_SONNET_MODEL=meta/llama-3.3-70b-instruct
# CLAUDE_CODE_DEFAULT_OPUS_MODEL=meta/llama-3.1-405b-instruct

# NOTE: FREE_ONLY is NOT used by wrapper-nvidia (NVIDIA NIM catalog is already free-tier accessible).
# FREE_ONLY applies only to wrapper-nous and wrapper-opencode.
