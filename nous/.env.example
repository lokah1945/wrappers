# wrapper-nous — production (transparent proxy)
NOUS_BASE_URL=https://inference-api.nousresearch.com
AUTH_PATH=/root/.hermes/profiles/ilma/auth.json
# NOUS_API_KEY=your-static-token

LISTEN_HOST=127.0.0.1
LISTEN_PORT=9106

# Optional alias targets only (sonnet/opus/haiku → these ids).
# The wrapper NEVER injects a model when the client omits one.
DEFAULT_MODEL=tencent/hy3:free
REASONING_MODEL=tencent/hy3:free

BEARER_TOKEN=wrapper-local-key

# FREE_ONLY=yes → catalog + requests limited to ids containing "free"
# FREE_ONLY=no  → transparent (default). Does not pick models for the client.
FREE_ONLY=no
# Optional free ids that do not contain the substring "free"
FREE_MODEL_ALLOWLIST=

HEARTBEAT_INTERVAL_MS=5000
RATE_LIMIT_RPM=60
MAX_CONCURRENT_STREAMS=32
