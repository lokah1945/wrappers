# Blackbox AI API Keys (add as many as needed, numbered 1-50)
BLACKBOX_API_KEY_1=sk-your-first-key
BLACKBOX_API_KEY_2=sk-your-second-key
BLACKBOX_API_KEY_3=sk-your-third-key

# Fallback single key (optional)
# BLACKBOX_API_KEY=sk-fallback-key

# Rate Limit Configuration
SOFT_LIMIT_RPM=30
HARD_LIMIT_RPM=40
MAX_RETRIES=5

# Server Configuration
LISTEN_HOST=127.0.0.1
LISTEN_PORT=9101

# Upstream Configuration
BLACKBOX_BASE_URL=https://api.blackbox.ai
REQUEST_TIMEOUT=600

# Background Tasks
MODELS_REFRESH_SECONDS=3600
KEYS_RELOAD_SECONDS=60
DATA_RETAIN_DAYS=30

# Connection Pool
MAX_CONNECTIONS=200

# Parameters to proactively drop from requests (comma-separated)
DROP_PARAMS=think