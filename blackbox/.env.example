# wrapper-blackbox — OpenAI + Anthropic compatible proxy for BLACKBOX AI
# Public API base per BLACKBOX docs: https://api.blackbox.ai
BLACKBOX_API_KEY_1=sk-your-blackbox-key-here
BLACKBOX_API_KEY_2=
BLACKBOX_API_KEY_3=
BLACKBOX_API_KEY_4=
BLACKBOX_API_KEY_5=

LISTEN_HOST=0.0.0.0
LISTEN_PORT=9104
BEARER_TOKEN=
BLACKBOX_BASE_URL=https://api.blackbox.ai

# Default for blackbox wrapper is FREE_ONLY=yes.
# Requests for non-free models are rejected unless FREE_ONLY=no.
FREE_ONLY=yes
# Free ids without substring "free" can be allowlisted here.
FREE_MODEL_ALLOWLIST=blackboxai/nvidia/nemotron-nano-12b-v2-vl
# Seed aliases (sonnet/haiku/opus/claude-*) to a known free model for Claude Code.
DYNAMIC_ALIAS_TARGET=blackboxai/nvidia/nemotron-3-super-120b-a12b:free

INFLIGHT_SOFT_CAP=100
SOFT_LIMIT_RPM=30
HARD_LIMIT_RPM=40
RATE_LIMIT_COOLDOWN_SEC=65
AUTH_KEY_COOLDOWN_SEC=300
TRANSIENT_KEY_COOLDOWN_SEC=15
KEY_COOLDOWN_MAX_SEC=300
HEARTBEAT_INTERVAL_MS=5000
REQUEST_TIMEOUT_SEC=600
STREAM_REQUEST_TIMEOUT_SEC=900
MAX_CONNECTIONS=200
MAX_CONNECTIONS_PER_HOST=100
CONNECT_TIMEOUT_SEC=30

# Persistent model catalog and account-scoped availability state.
MODEL_STATE_DB=model-state.db
MODEL_CATALOG_TTL_SEC=21600
# Background catalog refresh; inference traffic is independent.
MODEL_CATALOG_REFRESH_SEC=86400
# Optional central model-intelligence service; empty keeps local-only mode.
MODEL_REGISTRY_URL=
MODEL_REGISTRY_ADMIN_TOKEN=
