# OpenCode Zen keys (https://opencode.ai/auth)
OPENCODE_API_KEY_1=sk-your-zen-key-here
OPENCODE_API_KEY_2=

LISTEN_HOST=0.0.0.0
LISTEN_PORT=9103
BEARER_TOKEN=

# OpenCode Zen base — https://opencode.ai/docs/zen/
OPENCODE_BASE_URL=https://opencode.ai/zen/v1

# Dynamic aliases (NO hardcoded targets):
# Call minimaxai/minimax-m3 or z-ai/glm-5.2 (etc.) → sonnet/haiku/opus follow that model.
# Optional boot seed only:
# DYNAMIC_ALIAS_TARGET=deepseek-v4-flash-free
# DEFAULT_MODEL is unused for injection (legacy placeholder).
DEFAULT_MODEL=

# FREE_ONLY=yes → catalog + requests limited to ids containing "free"
# FREE_ONLY=no  → transparent (default). Does not pick/substitute models.
FREE_ONLY=no
# Free ids without substring "free" (Zen: big-pickle)
FREE_MODEL_ALLOWLIST=big-pickle

INFLIGHT_SOFT_CAP=100
ANTI_SILENCE_TIMEOUT_MS=960000
HEARTBEAT_INTERVAL_MS=5000
SOFT_LIMIT_RPM=30
HARD_LIMIT_RPM=40

# Multi-key resilience / cooldowns
RATE_LIMIT_COOLDOWN_SEC=65
AUTH_KEY_COOLDOWN_SEC=300
TRANSIENT_KEY_COOLDOWN_SEC=15
KEY_COOLDOWN_MAX_SEC=300

# Connection pool / performance
MAX_CONNECTIONS=200
MAX_CONNECTIONS_PER_HOST=100
CONNECT_TIMEOUT_SEC=30
REQUEST_TIMEOUT_SEC=600
STREAM_REQUEST_TIMEOUT_SEC=900

# Persistent model catalog and account-scoped availability state.
MODEL_STATE_DB=model-state.db
MODEL_CATALOG_TTL_SEC=21600
# Background catalog refresh; inference traffic is independent.
MODEL_CATALOG_REFRESH_SEC=86400
# Optional central model-intelligence service; empty keeps local-only mode.
MODEL_REGISTRY_URL=
MODEL_REGISTRY_ADMIN_TOKEN=
