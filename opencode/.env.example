# OpenCode Zen keys (https://opencode.ai/auth)
OPENCODE_API_KEY_1=sk-your-zen-key-here
OPENCODE_API_KEY_2=

LISTEN_HOST=0.0.0.0
LISTEN_PORT=9107
BEARER_TOKEN=

# OpenCode Zen base — https://opencode.ai/docs/zen/
OPENCODE_BASE_URL=https://opencode.ai/zen/v1

# Optional short-alias targets only (sonnet/opus/haiku).
# The wrapper NEVER injects a model when the client omits one — fully transparent.
DEFAULT_MODEL=gpt-5.4-mini
ALIAS_SONNET=claude-sonnet-4-6
ALIAS_OPUS=claude-opus-4-6
ALIAS_HAIKU=claude-haiku-4-5

# FREE_ONLY=yes → catalog + requests limited to ids containing "free"
# FREE_ONLY=no  → transparent (default). Does not pick/substitute models.
FREE_ONLY=no
# Free ids without substring "free" (Zen: big-pickle)
FREE_MODEL_ALLOWLIST=big-pickle

INFLIGHT_SOFT_CAP=100
ANTI_SILENCE_TIMEOUT_MS=960000
HEARTBEAT_INTERVAL_MS=5000
SOFT_LIMIT_RPM=30
HARD_LIMIT_RPM=40
