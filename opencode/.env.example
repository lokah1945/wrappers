# OPENCODE API Keys (add as many as needed)
OPENCODE_API_KEY_1=sk-your-key-here
OPENCODE_API_KEY_2=sk-your-key-here
OPENCODE_API_KEY_3=sk-your-key-here

# Server
LISTEN_HOST=0.0.0.0
LISTEN_PORT=9107
BEARER_TOKEN=

# OpenCode upstream (adjust if different)
OPENCODE_BASE_URL=https://api.opencode.ai

# Production hardening (same as nvidia-python)
INFLIGHT_SOFT_CAP=100
ANTI_SILENCE_TIMEOUT_MS=960000
TTFT_TIMEOUT_MS=120000
PRE_RESPONSE_TIMEOUT_MS=300000
HEADERS_TIMEOUT_MS=120000
MAX_STREAM_BUFFER_KB=512

# Key rotation
SOFT_LIMIT_RPM=30
HARD_LIMIT_RPM=40
QUEUE_LIMIT=4

# Optional
DEFAULT_MODEL=gpt-4o
BEARER_TOKEN=