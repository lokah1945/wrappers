# OpenCode Zen API keys (from https://opencode.ai/auth — /connect in TUI)
OPENCODE_API_KEY_1=sk-your-zen-key-here
OPENCODE_API_KEY_2=

# Server
LISTEN_HOST=0.0.0.0
LISTEN_PORT=9107
BEARER_TOKEN=

# OpenCode Zen base (MUST include /zen/v1 — see https://opencode.ai/docs/zen/)
OPENCODE_BASE_URL=https://opencode.ai/zen/v1

DEFAULT_MODEL=gpt-5.4-mini
ALIAS_SONNET=claude-sonnet-4-6
ALIAS_OPUS=claude-opus-4-6
ALIAS_HAIKU=claude-haiku-4-5

# FREE_ONLY=yes → only models with "free" in the name are listed/allowed
# FREE_ONLY=no  → all Zen models including paid GPT/Claude (default)
FREE_ONLY=no
# Optional: free ids that do NOT contain substring "free" (Zen: big-pickle)
FREE_MODEL_ALLOWLIST=big-pickle
# Default when FREE_ONLY=yes and client omits model
DEFAULT_FREE_MODEL=mimo-v2.5-free

# Production hardening
INFLIGHT_SOFT_CAP=100
ANTI_SILENCE_TIMEOUT_MS=960000
HEARTBEAT_INTERVAL_MS=5000
SOFT_LIMIT_RPM=30
HARD_LIMIT_RPM=40
