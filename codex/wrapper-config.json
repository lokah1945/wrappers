{
  "project": "Wrapper Project",
  "provider": "wrapper-codex",
  "version": "1.0.0",
  "description": "Local Codex CLI agent gateway with run pool, metrics, SSE streaming, and OpenAI-style compatibility shim.",
  "service": {
    "name": "codex-wrapper",
    "systemd": "codex-wrapper.service",
    "base_url": "http://127.0.0.1:9103",
    "upstream": "codex exec",
    "process_model": "single uvicorn process with in-memory RunPool"
  },
  "endpoints": {
    "GET /health": "service and run pool status",
    "GET /stats": "run pool and policy settings",
    "GET /dashboard": "HTML dashboard",
    "GET /metrics": "SQLite run metrics",
    "GET /v1/models": "static model hints",
    "POST /v1/runs": "native agent run endpoint",
    "GET /v1/runs/{id}": "run status and result",
    "GET /v1/runs/{id}/events": "recent captured run events",
    "POST /v1/runs/{id}/cancel": "cancel active non-streaming run",
    "POST /v1/chat/completions": "simple OpenAI-compatible adapter"
  },
  "port": 9103
}
