# ═══════════════════════════════════════════════════════════════════════════
# wrapper-nvidia v8.6.0 — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values.
# All variables are hot-reloaded — edit .env anytime, no restart needed.
# ═══════════════════════════════════════════════════════════════════════════

# ── NVIDIA NIM API Keys (Round-robin failover) ───────────────────────────
# At least one key required. Add as many as you have (NVIDIA_API_KEY_6, ...).
# Keys are loaded at startup and synced every KEYS_RELOAD_SECONDS.
NVIDIA_API_KEY_1=
NVIDIA_API_KEY_2=
NVIDIA_API_KEY_3=
NVIDIA_API_KEY_4=
NVIDIA_API_KEY_5=

# ── Server Configuration ─────────────────────────────────────────────────
LISTEN_HOST=0.0.0.0
LISTEN_PORT=9100
BEARER_TOKEN=
# Set BEARER_TOKEN to enable auth on all non-public endpoints.
# Clients must send Authorization: Bearer <token> or x-api-key: <token>.

# ── Rate Limit Settings ──────────────────────────────────────────────────
SOFT_LIMIT_RPM=30
HARD_LIMIT_RPM=40
QUEUE_LIMIT=1.0
# QUEUE_LIMIT: max requests admitted per key per second (token-bucket pacing).
# Set higher (e.g. 4) for bursty workloads; lower (0.5) for gentle upstream load.

# ── Key Pool Tuning ──────────────────────────────────────────────────────
KEYS_RELOAD_SECONDS=60
KEY_RETRY_INTERVAL_MS=5000
PACING_MAX_WAIT=60
# PACING_MAX_WAIT: max seconds a request waits in the admission queue before 503.

# ── 429 Classification Tuning ────────────────────────────────────────────
CORROBORATION_WINDOW_S=60
MODEL_BLOCK_CAP=10
KEY_BLOCK_CAP=30
MODEL_BLOCK_DEFAULT_SECS=8
KEY_LEVEL_RPM_RATIO=0.8

# ── Throughput & Stability ───────────────────────────────────────────────
MAX_CONNECTIONS=1000
# MAX_CONNECTIONS: undici pool size. Increase for high-concurrency deployments.
MAX_QUEUE_SIZE=500
# MAX_QUEUE_SIZE: max requests buffered in internal queue before 503 rejection.
INFLIGHT_SOFT_CAP=50
# INFLIGHT_SOFT_CAP: max concurrent in-flight requests to upstream. Exceeding
# triggers load shedding (503) when LOAD_SHEDDING_ENABLED=true.
LOAD_SHEDDING_ENABLED=true
# Set to 'false' to disable load shedding (requests queue instead of 503).

# ── Model Blocking Toggle ────────────────────────────────────────────────
BLOCK_UNAVAILABLE_MODELS=false
# Default 'false' = transparent proxy: all models pass through, upstream
# returns the real error. Set to 'true' to proactively 404 models that the
# verification sweep has marked unavailable (404/DEGRADED/consecutive timeouts).
# The verification infrastructure always runs regardless of this toggle.

# ── Request Timeouts ─────────────────────────────────────────────────────
REQUEST_TIMEOUT_SEC=120
# REQUEST_TIMEOUT_SEC: hard timeout per NON-STREAMING request to upstream.
STREAM_REQUEST_TIMEOUT_SEC=900
# STREAM_REQUEST_TIMEOUT_SEC: hard timeout per STREAMING request. Reasoning
# models (deepseek-v4-pro, Qwen3-thinking, ds-r1) can think for 5-15 minutes
# before first token. 900s = 15 min gives enough headroom.
GEN_TIMEOUT_SEC=900
# GEN_TIMEOUT_SEC: timeout for image/audio/video/ranking generation endpoints.
TTFT_TIMEOUT_MS=120000
# TTFT_TIMEOUT_MS: log a warning if time-to-first-token exceeds this (ms).

# ── Dead-Upstream Fail-Fast Guards (REVISI audit) ────────────────────────
PRE_RESPONSE_TIMEOUT_MS=45000
# PRE_RESPONSE_TIMEOUT_MS: hard ceiling on time-to-first-byte for the WHOLE
# request handler. If upstream blackholes (TLS connects but never sends HTTP
# response), this watchdog aborts the fetch and returns a clean 504.
READ_BODY_TIMEOUT_MS=30000
# READ_BODY_TIMEOUT_MS: bound on client request body upload. A stalled client
# that never finishes sending the body would otherwise leave readBody() pending
# forever.
# Undici agent timeouts (set in code; documented here):
#   connectTimeout=15000  — abort stalled TCP/TLS handshake
#   headersTimeout=30000  — abort if upstream never sends response headers
#   bodyTimeout=0         — keep allowing long silent thinking gaps in the body
#                          (reasoning models think for minutes before any delta)

# ── Server-Level Socket Timeouts ─────────────────────────────────────────
ANTI_SILENCE_TIMEOUT_MS=960000
# ANTI_SILENCE_TIMEOUT_MS: must be >= STREAM_REQUEST_TIMEOUT_SEC + 60s buffer
# so a healthy (heartbeating) stream is never killed by the server layer before
# the fetch timeout fires a clean abort.
SERVER_KEEPALIVE_TIMEOUT_MS=65000
SERVER_HEADERS_TIMEOUT_MS=35000

# ── Streaming ────────────────────────────────────────────────────────────
STREAM_HEARTBEAT=true
HEARTBEAT_INTERVAL_MS=5000
# HEARTBEAT_INTERVAL_MS: ping interval during idle periods in SSE streams.
MAX_STREAM_BUFFER_KB=512
# MAX_STREAM_BUFFER_KB: rolling buffer size for capturing usage chunks at
# stream end. Increase for very long streams (reasoning models).

# ── Request Body ─────────────────────────────────────────────────────────
MAX_BODY_MB=100
# MAX_BODY_MB: max request body size. Claude Code sessions can grow large
# (long history, tool_result blocks, base64 images).

# ── Parameter Injection ──────────────────────────────────────────────────
# Client parameters always win. DEFAULT_<PARAM> is only used as fallback when
# the client does not send that parameter. Leave empty to defer to NVIDIA NIM.
WRAPPER_PARAMS=temperature,top_p
DEFAULT_TEMPERATURE=0.7
DEFAULT_TOP_P=1.0
DROP_PARAMS=think
# DROP_PARAMS: comma-separated list of params to strip before upstream.
# 'think' is always included for backward compatibility. The wrapper also
# auto-strips forbidden context params (context_length, max_input_tokens, etc.).

# ── Model Discovery / Sync ───────────────────────────────────────────────
MODEL_REFRESH_SEC=600
VERIFY_CONCURRENCY=16
# VERIFY_CONCURRENCY: parallel probes during model verification sweep.
VERIFY_INTERVAL=600
# VERIFY_INTERVAL: seconds between model verification sweeps.
VERIFY_ON_BOOT=true
# Set to 'false' to skip the initial verification sweep at startup.

# ── Image Limits ─────────────────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# ── Authoritative Context Registry (NGC featured-models) ─────────────────
# Fetched periodically, cached locally (nvidia/ngc-featured-cache.json), and
# used to report accurate context_window / max_output_tokens. Falls back to
# the on-disk cache, then a tiny static seed, if unreachable. NEVER silently
# hardcoded guesses.
REGISTRY_REFRESH_SEC=3600
NGC_FEATURED_MODELS_URL=https://assets.ngc.nvidia.com/products/api-catalog/featured-models.json

# ── Claude Code / Anthropic Alias Mapping ────────────────────────────────
# NIM 404s Claude Code's built-in haiku/sonnet/opus aliases unless mapped to
# real NIM models. These make the gateway serve Claude Code without fallback.
CLAUDE_CODE_DEFAULT_HAIKU_MODEL=meta/llama-3.1-8b-instruct
CLAUDE_CODE_DEFAULT_SONNET_MODEL=deepseek-ai/deepseek-v4-pro
CLAUDE_CODE_DEFAULT_OPUS_MODEL=nvidia/nemotron-3-ultra-550b-a55b
# Optional arbitrary aliases (JSON: "client-alias" -> "owner/model")
# ANTHROPIC_ALIAS_MAP={"my-model":"deepseek-ai/deepseek-v4-flash"}

# ── Claude Code Gateway Feature ──────────────────────────────────────────
CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY=1

# ── Logging ──────────────────────────────────────────────────────────────
WRAPPER_JSON_LOG=true
# WRAPPER_JSON_LOG: enable structured JSON log sink to metrics_data/wrapper-events.jsonl

# ── Metrics DB ───────────────────────────────────────────────────────────
METRICS_DB=metrics.db
# METRICS_DB: path to SQLite metrics database. Default: metrics.db in wrapper root.

# ── Heal In-Flight ───────────────────────────────────────────────────────
HEAL_INFLIGHT_THRESHOLD_SEC=600
# HEAL_INFLIGHT_THRESHOLD_SEC: seconds of inactivity before healInFlight
# resets a stuck inFlight counter. Must be longer than the maximum silent
# thinking gap (reasoning models can think 5+ minutes without data).

# ── Upstream Routes (advanced) ───────────────────────────────────────────
# UPSTREAM_ROUTES={"custom/prefix":"https://other-upstream.example.com"}