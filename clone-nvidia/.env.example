# NVIDIA NIM API Keys (Round-robin failover)
NVIDIA_API_KEY_1=
NVIDIA_API_KEY_2=
NVIDIA_API_KEY_3=
NVIDIA_API_KEY_4=
NVIDIA_API_KEY_5=

# Server Configuration
LISTEN_HOST=0.0.0.0
LISTEN_PORT=9100
BEARER_TOKEN=

# Model Discovery / Sync
MODEL_REFRESH_SEC=600

# Limits
MAX_IMAGE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# Claude Code Gateway feature
CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY=1

# ── Authoritative context registry (NGC featured-models, machine-readable) ──
# Fetched periodically, cached locally (nvidia/ngc-featured-cache.json), and
# used to report accurate context_window / max_output_tokens. Falls back to the
# on-disk cache, then a tiny static seed, if unreachable. NEVER silently
# hardcoded guesses.
REGISTRY_REFRESH_SEC=3600
NGC_FEATURED_MODELS_URL=https://assets.ngc.nvidia.com/products/api-catalog/featured-models.json

# ── Claude Code / Anthropic alias mapping ──
# NIM 404s Claude Code's built-in haiku/sonnet/opus aliases unless mapped to
# real NIM models. These make the gateway serve Claude Code without fallback.
CLAUDE_CODE_DEFAULT_HAIKU_MODEL=meta/llama-3.1-8b-instruct
CLAUDE_CODE_DEFAULT_SONNET_MODEL=deepseek-ai/deepseek-v4-pro
CLAUDE_CODE_DEFAULT_OPUS_MODEL=nvidia/nemotron-3-ultra-550b-a55b
# Optional arbitrary aliases (JSON: "client-alias" -> "owner/model")
# ANTHROPIC_ALIAS_MAP={"my-model":"deepseek-ai/deepseek-v4-flash"}

# ── Generation endpoint timeout ──
# Image/audio/video/ranking generation can take minutes; the default 120s
# request timeout would abort them mid-generation. Use a longer timeout.
GEN_TIMEOUT_SEC=900

# ── Dead-upstream fail-fast guards (REVISI audit) ──
# PRE_RESPONSE_TIMEOUT_MS: hard ceiling on time-to-first-byte for the WHOLE
# request handler. If the upstream silently blackholes (TLS connects but never
# sends an HTTP response), the per-attempt undici headersTimeout + multi-key
# retry loop could still leave a patient client (e.g. Claude Code, which has no
# short client-side timeout) hanging for minutes. This watchdog aborts the
# upstream fetch once no response headers have been written within this window,
# so the handler's normal error path returns a clean 504 instead of stalling.
PRE_RESPONSE_TIMEOUT_MS=45000
# READ_BODY_TIMEOUT_MS: bound on how long we wait for the client to finish
# sending the request body. A stalled/aborted client that opens a request but
# never completes the body would otherwise leave readBody() pending forever.
READ_BODY_TIMEOUT_MS=30000
# Undici agent connect/headers timeouts (set in code; documented here):
#   connectTimeout=15000  — abort a stalled TCP/TLS handshake
#   headersTimeout=30000  — abort if upstream never sends response headers
#   bodyTimeout=0         — keep allowing long silent thinking gaps in the body
#                          (reasoning models think for minutes before any delta)

